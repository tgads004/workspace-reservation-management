        <messages/>
        <name>Hide Discuss Button</name>
        <order/>
        <script><![CDATA[function onLoad() {
    // Safely look up to the Next Experience Unified Navigation top-bar container
    try {
        var topDoc = window.top.document;
        if (topDoc) {
            // Locates the specific Sidebar "discuss" action element in Core UI
            var discussBtn = topDoc.querySelector('[data-action-name="discuss"]');
            if (discussBtn) {
                discussBtn.style.display = 'none';
            }
        }
    } catch (e) {
        // Keeps the console clean and logs errors safely without disrupting the form load
        jslog('Note: Sidebar component element not available or accessible in this view context.');
    }
}
]]></script>
